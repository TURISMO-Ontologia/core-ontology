}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#WinterSportsResort",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Centro turístico básicamente dedicado a la práctica del esquí y demás deportes de nieve y montaña, que forma un conjunto coordinado de medios de remonte mecánicos, pistas e instalaciones complementarias."
  }, {
    "@language" : "en",
    "@value" : "Tourist center basically dedicated to the practice of skiing and other snow and mountain sports, which forms a coordinated set of mechanical lifts, slopes and complementary facilities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "estación de deportes de invierno"
  }, {
    "@language" : "en",
    "@value" : "winter sports resort"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#SportFacility"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#YatchingPort",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Instalación ubicada en una zona costera o junto a un cuerpo de agua, que se utiliza para el amarre y resguardo de embarcaciones de recreo y deportivas, como yates, veleros, lanchas y otros tipos de barcos privados."
  }, {
    "@language" : "en",
    "@value" : "Installation located in a coastal area or next to a body of water, which is used for mooring and sheltering recreational and sports vessels, such as yachts, sailboats, motorboats and other types of private boats."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "puerto deportivo"
  }, {
    "@language" : "en",
    "@value" : "yachting port"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#SportFacility"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Zoo",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Lugar en que se conservan, cuidan y a veces se crían diversas especies animales para que sean contempladas por el público y para su estudio."
  }, {
    "@language" : "en",
    "@value" : "Place where various animal species are conserved, cared for and sometimes raised so that they can be seen by the public and for study."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "zoo"
  }, {
    "@language" : "es",
    "@value" : "zoológico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"
