}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#EmergencyService112",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Single emergency telephone number for the entire European Union where you can communicate any emergency, whether in the field of aid and rescue, health, traffic and security."
  }, {
    "@language" : "es",
    "@value" : "Teléfono único de emergencias para toda la Unión Europea donde se puede comunicar cualquier emergencia, ya sea del ámbito de auxilio y rescate, sanitario, de tráfico y seguridad."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "emergency service 112"
  }, {
    "@language" : "es",
    "@value" : "servicio de emergencia 112"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#PublicService"
  } ]
