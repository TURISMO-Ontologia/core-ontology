    "@language" : "en",
    "@value" : "Company that is mainly responsible for the design, planning, coordination, as well as the production and execution of an event."
  }, {
    "@language" : "es",
    "@value" : "Empresa que se encarga principalmente del diseño, la planificación, la coordinación, así como la producción y ejecución de un evento."
  } ],
