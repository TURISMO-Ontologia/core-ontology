}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#EducationalFacility",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Espacios dedicados al aprendizaje y desarrollo de habilidades donde los participantes, generalmente niños o jóvenes, participan en actividades educativas, recreativas y sociales fuera del entorno escolar tradicional y con un enfoque generalmente temático."
  }, {
    "@language" : "en",
    "@value" : "Spaces dedicated to learning and skill development where participants, generally children or young people, participate in educational, recreational and social activities outside the traditional school environment and with a generally thematic focus."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "educational facility"
  }, {
    "@language" : "es",
    "@value" : "instalación educativa"
  } ],
