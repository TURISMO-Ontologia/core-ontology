  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento público, de carácter popular, donde se sirven y expenden bebidas y, a veces, se sirven comidas."
  }, {
    "@language" : "en",
    "@value" : "Public establishment, of a popular nature, where drinks are served and sold and, sometimes, meals are served."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "taberna"
  }, {
    "@language" : "en",
    "@value" : "tavern"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#RestaurantService"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TaxiStand",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Lugar en que se detienen los taxis a la espera de pasajeros."
  }, {
    "@language" : "en",
    "@value" : "Place where taxis stop waiting for passengers."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "parada de taxis"
  }, {
    "@language" : "en",
    "@value" : "taxi stand"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#TransportInfrastructure"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TeaRoom",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento especializado en la venta y servicio de tés e infusiones de todo el mundo."
  }, {
    "@language" : "en",
    "@value" : "Establishment specialized in the sale and service of teas and infusions from around the world."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "tea room"
  }, {
    "@language" : "es",
    "@value" : "tetería"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#RestaurantService"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TelephoneShop",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento de venta al por menor de artículos de telefonía, teléfonos móviles y accesorios."
  }, {
    "@language" : "en",
    "@value" : "Retail establishment of telephone items, mobile phones and accessories."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "telephone shop"
  }, {
    "@language" : "es",
    "@value" : "tienda de telefonía"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TemporaryClosure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Suspensión temporal de las operaciones de un negocio, establecimiento o servicio durante un período específico por razones como mantenimiento, renovación, reestructuración, falta de personal, emergencias, situaciones extraordinarias o por vacaciones."
  }, {
    "@language" : "en",
    "@value" : "Temporary suspension of the operations of a business, establishment or service for a specific period for reasons such as maintenance, renovation, restructuring, lack of personnel, emergencies, extraordinary situations or vacations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "cierre temporal"
  }, {
    "@language" : "en",
    "@value" : "temporary closure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid985"
  }, {
    "@id" : "_:genid986"
  }, {
    "@id" : "_:genid987"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TennisCourt",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Campo de juego donde se juega al tenis."
  }, {
    "@language" : "en",
    "@value" : "Playing field where tennis is played."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "pista de tenis"
  }, {
    "@language" : "en",
    "@value" : "tennnis court"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#SportFacility"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Theater",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Building or site intended for the representation of dramatic works or other public spectacles typical of the scene."
  }, {
    "@language" : "es",
    "@value" : "Edificio o sitio destinado a la representación de obras dramáticas o a otros espectáculos públicos propios de la escena."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "teatro"
  }, {
    "@language" : "en",
    "@value" : "theater"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#LeisureAndCultureFacility"
  }, {
    "@id" : "_:genid988"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TobaccoShop",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Site or store where stamps and tobacco are mainly sold, in addition to offering recharge services for prepaid telephone and urban transport cards."
  }, {
    "@language" : "es",
    "@value" : "Sitio o tienda donde se venden principalmente sellos y tabaco, además de ofrecer servicios de recarga de tarjetas prepago de telefonía y de transportes urbanos."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "estanco"
  }, {
    "@language" : "en",
    "@value" : "tobacco shop"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Tour",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Experiencia turística que incluye el recorrido por algún lugar o recinto de interés, que se hace generalmente en grupo y con la ayuda de un guía que conduce y proporciona información acerca de lo que se muestra."
  }, {
    "@language" : "en",
    "@value" : "Tourist experience that includes a tour of a place or area of ​​interest, which is generally done in a group and with the help of a guide who drives and provides information about what is shown."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "tour"
  }, {
    "@language" : "es",
    "@value" : "visita guiada"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#TourismService"
  }, {
    "@id" : "_:genid989"
  }, {
    "@id" : "_:genid990"
  }, {
    "@id" : "_:genid991"
  }, {
    "@id" : "_:genid992"
  }, {
    "@id" : "_:genid993"
  }, {
    "@id" : "_:genid994"
  }, {
    "@id" : "_:genid995"
  }, {
    "@id" : "_:genid996"
  }, {
    "@id" : "_:genid997"
  }, {
    "@id" : "_:genid998"
  }, {
    "@id" : "_:genid999"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TourGuide",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Person with extensive knowledge of the destination, capable of expressing himself in two or more languages, whose responsibility is to serve, inform and assist tourists on the tours they take."
  }, {
    "@language" : "es",
    "@value" : "Persona con amplio conocimiento del destino, capaz de expresarse en dos o más idiomas, cuya responsabilidad es atender, informar y asistir a los turistas en los tours que realizan."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "guía turístico"
  }, {
    "@language" : "en",
    "@value" : "tour guide"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#Organisation"
  }, {
    "@id" : "_:genid1000"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TourOperator",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Operador que ofrece productos o servicios turísticos, generalmente contratados por él e integrados por más de uno de los siguientes servicios: transporte, alojamiento, traslados, excursiones, etc. Puede ser operador mayorista, si trabaja exclusivamente con agencias de viajes, o mayorista y minorista, en caso de que su oferta vaya también destinada al cliente final."
  }, {
    "@language" : "en",
    "@value" : "Operator that offers tourist products or services, generally contracted by it and consisting of more than one of the following services: transportation, accommodation, transfers, excursions, etc. You can be a wholesale operator, if you work exclusively with travel agencies, or a wholesaler and retailer, if your offer is also intended for the end customer."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "tour operator"
  }, {
    "@language" : "es",
    "@value" : "turoperador"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"
  }, {
    "@id" : "_:genid1001"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TourismResource",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Lugar, sitio o elemento que tiene un valor significativo y atractivo para los turistas y es capaz de motivar su desplazamiento. Suelen ser destacados por su belleza escénica, importancia histórica, singularidad cultural o valor recreativo."
  }, {
    "@language" : "en",
    "@value" : "Place, site or element that has a significant and attractive value for tourists and is capable of motivating their movement. They are often noted for their scenic beauty, historical importance, cultural uniqueness, or recreational value."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Recurso turístico"
  }, {
    "@language" : "en",
    "@value" : "Tourism Resource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid1002"
  }, {
    "@id" : "_:genid1003"
  }, {
    "@id" : "_:genid1004"
  }, {
    "@id" : "_:genid1005"
  }, {
    "@id" : "_:genid1006"
  }, {
    "@id" : "_:genid1007"
  }, {
    "@id" : "_:genid1008"
  }, {
    "@id" : "_:genid1009"
  }, {
    "@id" : "_:genid1010"
  }, {
    "@id" : "_:genid1011"
  }, {
    "@id" : "_:genid1012"
  }, {
    "@id" : "_:genid1013"
  }, {
    "@id" : "_:genid1014"
  }, {
    "@id" : "_:genid1015"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TourismService",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Clase que agrupa de manera general los servicios relevantes para el sector turístico, donde se aplicarán las propiedades comunes a todos estos servicios."
  }, {
    "@language" : "en",
    "@value" : "Class that groups in a general manner all services that are relevant for the tourism sector, so as to group all common properties to all these services."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Servicio turístico"
  }, {
    "@language" : "en",
    "@value" : "Tourism Service"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid1016"
  }, {
    "@id" : "_:genid1017"
  }, {
    "@id" : "_:genid1018"
  }, {
    "@id" : "_:genid1019"
  }, {
    "@id" : "_:genid1020"
  }, {
    "@id" : "_:genid1021"
  }, {
    "@id" : "_:genid1022"
  }, {
    "@id" : "_:genid1023"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Tourist",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Person who travels, spends the night and purchases a product or service at least once, in a destination other than their usual environment, for a duration of less than one year, with any main purpose other than being employed by an entity resident in the country or place visited"
  }, {
    "@language" : "es",
    "@value" : "Persona que viaja, pernocta y ejerce la acción de compra de un producto o servicio como mínimo una vez, en un destino distinto al de su entorno habitual, por una duración inferior a un año, con cualquier finalidad principal que no sea la de ser empleado por una entidad residente en el país o lugar visitado"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "tourist"
  }, {
    "@language" : "es",
    "@value" : "turista"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#PersonRole"
  }, {
    "@id" : "_:genid1024"
  }, {
    "@id" : "_:genid1025"
  }, {
    "@id" : "_:genid1026"
  }, {
    "@id" : "_:genid1027"
  }, {
    "@id" : "_:genid1028"
  }, {
    "@id" : "_:genid1029"
  }, {
    "@id" : "_:genid1030"
  }, {
    "@id" : "_:genid1031"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristAttractionSite",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Espacio delimitado en el que se reúnen diferentes atractivos que no son exclusivamente turísticos, pero que en razón de sus condiciones y singularidad suscitan interés para la actividad turística."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "conjunto de interés artístico"
  }, {
    "@language" : "en",
    "@value" : "tourist attraction site"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#HistoricalAndCulturalResource"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristDestination",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Espacio físico, con o sin una delimitación de carácter administrativo o analítico, en el que un visitante puede pernoctar."
  }, {
    "@language" : "en",
    "@value" : "Physical space, with or without an administrative or analytical delimitation, in which a visitor can spend the night."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "destino turístico"
  }, {
    "@language" : "en",
    "@value" : "tourist destination"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Thing"
  }, {
    "@id" : "_:genid1032"
  }, {
    "@id" : "_:genid1033"
  }, {
    "@id" : "_:genid1034"
  }, {
    "@id" : "_:genid1035"
  }, {
    "@id" : "_:genid1036"
  }, {
    "@id" : "_:genid1037"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristDestinationService",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "servicio de destino turístico"
  }, {
    "@language" : "en",
    "@value" : "tourist destination service"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#TourismService"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristInformationOffice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Organización encargada de proveer información a los turistas potenciales y turistas que visitan un determinado lugar."
  }, {
    "@language" : "en",
    "@value" : "Organization in charge of providing information to potential tourists and tourists who visit a certain place"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "oficina de turismo"
  }, {
    "@language" : "en",
    "@value" : "tourist information office"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#PublicService"
  }, {
    "@id" : "_:genid1038"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristInformationPoint",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Espacio ubicado en lugares de máxima afluencia donde se ofrece información de interés al visitante."
  }, {
    "@language" : "en",
    "@value" : "Space located in places of maximum influx where information of interest to the visitor is offered"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "puesto de información turística"
  }, {
    "@language" : "en",
    "@value" : "tourist information point"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#PublicService"
  }, {
    "@id" : "_:genid1039"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristIntermediary",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Agente de distribución que participa en la venta y/o corretaje de productos y servicios relacionados con viajes y turismo."
  }, {
    "@language" : "en",
    "@value" : "Distribution agent that participates in the sale and/or brokerage of products and services related to travel and tourism."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "intermediario turístico"
  }, {
    "@language" : "en",
    "@value" : "tourist intermediary"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#Organisation"
  }, {
    "@id" : "_:genid1040"
  }, {
    "@id" : "_:genid1041"
  } ]
}, {
