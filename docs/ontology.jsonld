  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Game that is based on solving a series of tests and finding objects with the objective of escaping from a room."
  }, {
    "@language" : "es",
    "@value" : "Juego que se basa en resolver una serie de pruebas y encontrar objetos con el objetivo de escapar de una habitación."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "escape room"
  }, {
    "@language" : "es",
