    "@language" : "es",
    "@value" : "Principio que se impone para dirigir la conducta, la correcta realización de una acción o el correcto desarrollo de una actividad."
  }, {
    "@language" : "en",
    "@value" : "Principle that is imposed to direct behavior, the correct performance of an action or the correct development of an activity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "regla"
  }, {
    "@language" : "en",
    "@value" : "visit rule"
  } ],
