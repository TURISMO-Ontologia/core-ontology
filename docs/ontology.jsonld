  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#DestinationExperience",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Price-free experiences that the destination proposes so that the tourist integrates into the way of life of its inhabitants, their culture and their authenticity, to motivate the completion of the trip or so that they take away a memory that survives after it and can be transmitted to others. It allows establishing an emotional relationship between the tourist and the inhabitants of the destination."
  }, {
    "@language" : "es",
    "@value" : "Vivencias libres de precio que el destino propone para que el turista se integre en la forma de vivir de sus habitantes, su cultura y su autenticidad, para motivar la realización del viaje o bien para que se lleve un recuerdo que perviva después del mismo y pueda ser transmitido a los demás. Permite establecer una relación emocional entre el turista y los habitantes del destino."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "destination experience"
  }, {
    "@language" : "es",
    "@value" : "experiencia en destino"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#TourismService"
  }, {
    "@id" : "_:genid802"
  }, {
    "@id" : "_:genid803"
  }, {
    "@id" : "_:genid804"
  }, {
    "@id" : "_:genid805"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#DestinationManagementCompany",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Company specialized in the organization and management of tourist services for foreign visitors in a specific destination."
  }, {
    "@language" : "es",
    "@value" : "Empresa especializada en la organización y gestión de servicios turísticos para visitantes extranjeros en un destino específico."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "destination management company"
  }, {
    "@language" : "es",
    "@value" : "operador receptivo"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#TouristIntermediary"
  }, {
    "@id" : "_:genid806"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#DryCleaningOrLaundry",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento en el que se tiñen, se planchan o se limpian en seco o mediante otro procedimiento tejidos y prendas de vestir."
  }, {
    "@language" : "en",
    "@value" : "Establishment in which fabrics and clothing are dyed, ironed, dry cleaned or otherwise cleaned."
  } ],
