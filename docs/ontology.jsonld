    "@language" : "es",
    "@value" : "Lugar que provee electricidad para la recarga rápida de las baterías de los vehículos eléctricos."
  }, {
    "@language" : "en",
    "@value" : "Place that provides electricity for the rapid recharging of electric vehicle batteries."
  } ],
