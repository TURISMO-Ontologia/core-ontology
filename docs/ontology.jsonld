}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#CruiseLine",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Empresa naviera o conjunto de empresas navieras, del mismo grupo empresarial, dedicados a ofrecer servicios de viajes en crucero, operando una flota de buques de pasajeros tipo crucero turístico diseñados para el entretenimiento y transporte de pasajeros en viajes de placer."
  }, {
    "@language" : "en",
    "@value" : "Shipping company or group of shipping companies, from the same business group, dedicated to offering cruise travel services, operating a fleet of tourist cruise type passenger ships designed for the entertainment and transportation of passengers on pleasure trips."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "compañía de cruceros"
  }, {
    "@language" : "en",
    "@value" : "cruise line"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#PassengerTransportCompany"
  }, {
    "@id" : "_:genid794"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#CruiseShip",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Barco de pasajeros que realiza viajes con fines vacacionales o turísticos a cualquier parte del mundo haciendo escala en destinos intermedios, que proporciona a sus pasajeros todos los servicios propios de un hotel, como alojamiento, manutención, servicio médico, actividades de entretenimiento, etc."
  }, {
    "@language" : "en",
    "@value" : "Passenger ship that makes trips for vacation or tourism purposes to any part of the world, stopping at intermediate destinations, which provides its passengers with all the services of a hotel, such as accommodation, food, medical service, entertainment activities, etc."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "crucero"
  }, {
    "@language" : "en",
    "@value" : "cruise ship"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
