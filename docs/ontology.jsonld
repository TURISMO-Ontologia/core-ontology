    "@value" : "Actividad"
  }, {
    "@language" : "en",
    "@value" : "Activity"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#AdditionalInformation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Additional details, data or explanations that complement or expand the main information provided. It is extra information that can provide clarification, context, or specific details on a given topic."
  }, {
    "@language" : "es",
    "@value" : "Detalles, datos o explicaciones adicionales que complementan o amplían la información principal proporcionada. Es información extra que puede proporcionar aclaraciones, contexto o detalles específicos sobre un tema determinado."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "additional information"
  }, {
    "@language" : "es",
    "@value" : "información adicional"
  } ],
