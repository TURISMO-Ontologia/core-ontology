}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/elements/1.1/rights" : [ {
    "@value" : "Creative Commons Attribution Non-Commercial No-Derivatives 4.0 International (CC BY-NC-ND 4.0)"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "es",
    "@value" : "Esta ontología de dominio del sector turístico está construida a partir del Modelo Conceptual de Referencia Semántico de Turismo de SEGITTUR, un modelo para el desarrollo de una Red de Ontologías del Sector Turístico al servicio de la futura Plataforma Inteligente de Destino (PID) promovida por SEGITTUR. El Modelo Conceptual de Referencia de Turismo de SEGITTUR ofrece un corazón ontológico extensible para conceptos e información sobre el dominio de turismo, y aspira a convertirse en una referencia para el intercambio controlado de información sobre turismo."
  }, {
    "@language" : "en",
    "@value" : "This tourism domain ontology is built from SEGITTUR's Conceptual Tourism Semantic Reference Model, a model for the development of a Network of Tourism Sector Ontologies at the service of the future Intelligent Destination Platform (IDP) promoted by SEGITTUR. The SEGITTUR Conceptual Tourism Reference Model offers an extensible ontological core for concepts and information on the tourism domain, and aims to become a reference for the controlled exchange of tourism information."
  } ],
  "http://purl.org/dc/terms/hasFormat" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core.owl"
  } ],
  "http://purl.org/dc/terms/issued" : [ {
    "@value" : "2025-01-26"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by-nc-nd/4.0/"
  }, {
    "@value" : "CC BY-NC-ND"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Core ontology for tourism by SEGITTUR"
  }, {
    "@language" : "es",
    "@value" : "Ontología de referencia de turismo de SEGITTUR"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "estur"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#"
  } ],
  "http://www.w3.org/2002/07/owl#priorVersion" : [ {
    "@value" : "1.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core/1.1.1"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.1.1"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#ATM",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Machine computer-connected to a bank that allows certain banking operations to be carried out using a card or magnetic book that has a personal password assigned to it."
  }, {
    "@language" : "es",
    "@value" : "Máquina conectada informáticamente con un banco que permite efectuar ciertas operaciones bancarias mediante una tarjeta o libreta magnética que tienen asignada una clave personal."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ATM"
  }, {
    "@language" : "es",
    "@value" : "cajero automático"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#FinancialService"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#AccesoriesAndComplements",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Establecimiento en el que se venden objetos que complementan la indumentaria de una persona, como bolsos, calzado, paraguas, corbatas, sombreros, gafas, guantes, etc."
  }, {
    "@language" : "en",
    "@value" : "Establishment in which objects that complement a person's clothing are sold, such as bags, footwear, umbrellas, ties, hats, glasses, gloves, etc."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "accesories and complements"
  }, {
    "@language" : "es",
    "@value" : "tienda de accesorios y complementos"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#RetailAndFashion"
  } ]
}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Accommodation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Lugar donde una persona o un grupo de personas se hospeda, se aposenta o acampa."
  }, {
    "@language" : "en",
    "@value" : "Place where a person or a group of people stays, stays or camps."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Accommodation"
  }, {
    "@language" : "es",
    "@value" : "Alojamiento"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontologia.segittur.es/turismo/def/core#TourismService"
  }, {
