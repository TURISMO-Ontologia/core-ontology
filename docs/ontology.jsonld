  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Lugar o punto elevado desde el cual puede contemplarse con facilidad un paisaje."
  }, {
    "@language" : "en",
    "@value" : "Place or elevated point from which a landscape can be easily seen"
