}, {
  "@id" : "https://ontologia.segittur.es/turismo/def/core#Volcano",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Abertura en la tierra, y más comúnmente en una montaña, por donde salen de tiempo en tiempo humo, llamas y materias encendidas o derretidas."
  }, {
    "@language" : "en",
    "@value" : "Opening in the earth, and more commonly in a mountain, through which smoke, flames, and burning or melted matter emerge from time to time."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "volcano"
  }, {
    "@language" : "es",
    "@value" : "volcán"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
