  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Período de tiempo específico dentro del programa o agenda del evento en el cual se lleva a cabo una actividad o conjunto de actividades relacionadas."
  }, {
    "@language" : "en",
    "@value" : "Specific period of time within the event program or agenda in which an activity or set of related activities is carried out."
  } ],
