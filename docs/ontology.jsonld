    "@language" : "es",
    "@value" : "Lugar donde se exponen, guardan, venden e incluso se catan o degustan distintas clases de vinos."
  }, {
    "@language" : "en",
    "@value" : "Place where different types of wines are exhibited, stored, sold and even tasted or tasted"
  } ],
