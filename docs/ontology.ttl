                      ] ;
           rdfs:label "cabin type"@en ,
                      "tipo de cabina"@es .


###  https://ontologia.segittur.es/turismo/def/core#campingSpecialty
:campingSpecialty rdf:type owl:ObjectProperty ;
                  rdfs:domain :Camping ;
                  rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                      owl:hasValue <https://ontologia.segittur.es/turismo/kos/CampingSpecialty>
                                                    ]
                                                  ) ;
